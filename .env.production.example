APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
CERT_NAME=opsflow

DATABASE_URL=postgresql://opsflow:replace-with-a-strong-password@your-rds-endpoint:5432/opsflow?schema=public&sslmode=require
SERVER_UPLOADS_DIR=/srv/opsflow/uploads

CLIENT_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com/api

JWT_ACCESS_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN_MINUTES=15
JWT_REFRESH_EXPIRES_IN_DAYS=7
AUTH_SESSION_LIMIT=5
BCRYPT_SALT_ROUNDS=10
INVITATION_EXPIRES_IN_DAYS=7
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
